# Server
PORT=3001

# InBody Developers API
INBODY_API_BASE_URL=https://inbodywebapi.lookinbody.com
INBODY_ACCOUNT=your_lbweb_account
INBODY_API_KEY=your_api_key_here

# MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=inbody_crm

# Optional webhook custom header validation
WEBHOOK_HEADER_NAME=X-InBody-Secret
WEBHOOK_HEADER_VALUE=your_secret_value
